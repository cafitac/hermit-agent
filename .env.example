# HermitAgent environment variables example
# Copy and save as .env: cp .env.example .env

# ─── Local LLM (ollama) ────────────────────────────────
HERMIT_LLM_URL=http://localhost:11434/v1
HERMIT_MODEL=qwen3-coder:30b
# HERMIT_API_KEY=          # Gateway API key — only needed when reaching a remote Hermit gateway (e.g. ngrok); optional for local use

# ─── z.ai / GLM (external) ───────────────────────────────
# HERMIT_LLM_URL=https://api.z.ai/api/paas/v4
# HERMIT_MODEL=glm-5.1     # High performance (quality/code)
# HERMIT_MODEL=glm-4.7     # Fast response (speed/fast)
# Z_AI_API_KEY=your_z_ai_api_key_here

# ─── External ollama server ─────────────────────────────
# HERMIT_LLM_URL=http://your-server:11434/v1
# HERMIT_MODEL=qwen3-coder:30b
# HERMIT_API_KEY=your_proxy_bearer_token

# ─── MCP Server → Gateway delegation ─────────────────────
# Used when MCP Server delegates task execution to AI Gateway
# HERMIT_MCP_GATEWAY_URL=http://127.0.0.1:8765
# HERMIT_MCP_GATEWAY_API_KEY=your_gateway_api_key_here
